{
  "name": "tanstack-query-react-v5-docs",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "pnpm lint:fix",
    "format:check": "pnpm lint",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "simple-git-hooks",
    "sync:docs": "node scripts/sync-tanstack-query-react-v5.mjs",
    "sync:check": "node scripts/check-upstream-update.mjs",
    "i18n:check": "node scripts/check-i18n-status.mjs"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.37.6",
    "astro": "^5.6.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@astrojs/check": "^0.9.6",
    "astro-eslint-parser": "^1.3.0",
    "eslint": "^9.39.3",
    "eslint-plugin-astro": "^1.6.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run check && pnpm run lint && pnpm run i18n:check"
  }
}
