---
const target = '/framework/react/overview/';
const canonical = Astro.site ? new URL(target, Astro.site).toString() : target;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta http-equiv="refresh" content={`0;url=${target}`} />
		<meta name="robots" content="noindex" />
		<link rel="canonical" href={canonical} />
		<script is:inline>
			window.location.replace('/framework/react/overview/');
		</script>
		<title>Redirecting</title>
	</head>
	<body style="display: none;"></body>
</html>
